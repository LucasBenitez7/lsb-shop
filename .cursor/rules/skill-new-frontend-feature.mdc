# Skill: Creating a new frontend feature

Use when asked to add a new section, page, or feature to the frontend.

## Structure to create

```
features/{domain}/
├── components/
│   ├── {Domain}List.tsx          → Server Component (default, no 'use client')
│   ├── {Domain}Card.tsx          → Server Component
│   └── {Domain}Actions.tsx       → Client Component ('use client' — has events/state)
└── hooks/
    └── use{Domain}.ts            → Client hook for mutations/UI state

lib/api/{domain}/
├── drf.ts                        → DRF response interfaces (snake_case, matches JSON)
├── mappers.ts                    → DRF → TypeScript transformations
├── server.ts                     → serverFetchJson reads (server-only)
├── mutations.ts                  → Server Actions "use server"
└── index.ts                      → re-exports for consumers

types/{domain}.ts                 → TypeScript types used across features
```

## Step 1 — DRF types in lib/api/{domain}/drf.ts

```typescript
// lib/api/{domain}/drf.ts
// Mirror the exact JSON shape that Django returns (snake_case).
export interface Drf{Domain} {
  id: number
  name: string
  is_active: boolean
  created_at: string
  updated_at: string
}
```

## Step 2 — TypeScript types in types/{domain}.ts

```typescript
// types/{domain}.ts — camelCase, used across all features
export interface {Domain}Item {
  id: string
  name: string
  isActive: boolean
  createdAt: string
}
```

## Step 3 — Mapper in lib/api/{domain}/mappers.ts

```typescript
// lib/api/{domain}/mappers.ts
import type { Drf{Domain} } from "./drf"
import type { {Domain}Item } from "@/types/{domain}"

export function mapDrf{Domain}(row: Drf{Domain}): {Domain}Item {
  return {
    id: String(row.id),
    name: row.name,
    isActive: row.is_active,
    createdAt: row.created_at,
  }
}
```

## Step 4 — Server reads in lib/api/{domain}/server.ts

```typescript
// lib/api/{domain}/server.ts
// Server-only: uses serverFetchJson which forwards the session cookie.
import type { PaginatedResponse } from "@/lib/api/client"
import { serverFetchJson } from "@/lib/api/server-django"
import type { Drf{Domain} } from "./drf"
import { mapDrf{Domain} } from "./mappers"
import type { {Domain}Item } from "@/types/{domain}"

export async function getAdmin{Domain}List(): Promise<{Domain}Item[]> {
  try {
    const res = await serverFetchJson<PaginatedResponse<Drf{Domain}>>(
      "/api/v1/{domain}/?page_size=100"
    )
    return res.results.map(mapDrf{Domain})
  } catch {
    return []
  }
}
```

## Step 5 — Mutations in lib/api/{domain}/mutations.ts

```typescript
// lib/api/{domain}/mutations.ts
"use server"

import { revalidatePath } from "next/cache"
import { serverMutationJson } from "@/lib/api/server-django"

export async function create{Domain}Action(
  _prev: { error?: string },
  formData: FormData,
): Promise<{ error?: string }> {
  try {
    const name = (formData.get("name") as string).trim()
    await serverMutationJson("/api/v1/{domain}/", "POST", { name })
    revalidatePath("/admin/{domain}")
    return {}
  } catch (e) {
    return { error: e instanceof Error ? e.message : "Error al guardar." }
  }
}

export async function delete{Domain}Action(id: string): Promise<{ error?: string }> {
  try {
    await serverMutationJson(`/api/v1/{domain}/${encodeURIComponent(id)}/`, "DELETE")
    revalidatePath("/admin/{domain}")
    return {}
  } catch (e) {
    return { error: e instanceof Error ? e.message : "Error al eliminar." }
  }
}
```

## Step 6 — Server Component (list page)

```typescript
// features/{domain}/components/{Domain}List.tsx
// No 'use client' — Server Component, fetches on every request
import { getAdmin{Domain}List } from "@/lib/api/{domain}/server"
import { {Domain}Card } from "./{Domain}Card"
import { EmptyState } from "@/features/catalog/components"

export async function {Domain}List() {
  const items = await getAdmin{Domain}List()

  if (items.length === 0) {
    return (
      <EmptyState
        title="Sin {domain} todavía"
        description="Crea el primero para empezar."
      />
    )
  }

  return (
    <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item) => (
        <{Domain}Card key={item.id} item={item} />
      ))}
    </div>
  )
}
```

## Step 7 — Client Component (actions)

```typescript
// features/{domain}/components/{Domain}Actions.tsx
"use client"

import { useTransition } from "react"
import { toast } from "sonner"
import { delete{Domain}Action } from "@/lib/api/{domain}/mutations"
import type { {Domain}Item } from "@/types/{domain}"

export function {Domain}Actions({ item }: { item: {Domain}Item }) {
  const [isPending, startTransition] = useTransition()

  const handleDelete = () => {
    startTransition(async () => {
      const result = await delete{Domain}Action(item.id)
      if (result.error) {
        toast.error("No pudimos eliminar el elemento. Inténtalo de nuevo.")
      } else {
        toast.success("{Domain} eliminado correctamente.")
      }
    })
  }

  return (
    <button onClick={handleDelete} disabled={isPending}>
      {isPending ? "Eliminando..." : "Eliminar"}
    </button>
  )
}
```

## Step 8 — Form with React Hook Form + Zod

```typescript
// features/{domain}/components/{Domain}Form.tsx
"use client"

import { useActionState } from "react"
import { useForm } from "react-hook-form"
import { zodResolver } from "@hookform/resolvers/zod"
import { z } from "zod"
import { create{Domain}Action } from "@/lib/api/{domain}/mutations"

const schema = z.object({
  name: z.string().min(1, "El nombre es obligatorio").max(255),
})
type FormData = z.infer<typeof schema>

export function {Domain}Form() {
  const [state, formAction, isPending] = useActionState(create{Domain}Action, {})
  const { register, handleSubmit, formState: { errors } } = useForm<FormData>({
    resolver: zodResolver(schema),
  })

  return (
    <form action={formAction} className="space-y-4">
      <div>
        <input {...register("name")} name="name" placeholder="Nombre" />
        {errors.name && <p className="text-red-500 text-sm">{errors.name.message}</p>}
        {state.error && <p className="text-red-500 text-sm">{state.error}</p>}
      </div>
      <button type="submit" disabled={isPending}>
        {isPending ? "Guardando..." : "Guardar"}
      </button>
    </form>
  )
}
```

## Step 9 — Route page in app/

```typescript
// app/(admin)/admin/{domain}/page.tsx
import { {Domain}List } from "@/features/{domain}/components/{Domain}List"
import type { Metadata } from "next"

export const dynamic = "force-dynamic"

export const metadata: Metadata = {
  title: "{Domain} | LSB Shop Admin",
}

export default async function {Domain}Page() {
  return (
    <div className="space-y-4">
      <h1 className="text-2xl font-semibold">{Domain}</h1>
      <{Domain}List />
    </div>
  )
}
```

## Checklist

- [ ] `drf.ts` mirrors exact JSON from Django (snake_case)
- [ ] `mappers.ts` converts every field — no direct use of DRF types in components
- [ ] `server.ts` uses `serverFetchJson` (never `apiGet` for auth-protected reads)
- [ ] `mutations.ts` starts with `"use server"` and calls `revalidatePath`
- [ ] Server Components have no `'use client'`
- [ ] Client Components use `useTransition` for Server Action calls
- [ ] Toast messages in human language — never raw `error.message`
- [ ] Loading and empty states handled
- [ ] `page.tsx` exports `metadata`
- [ ] `export const dynamic = "force-dynamic"` on pages that fetch per-request

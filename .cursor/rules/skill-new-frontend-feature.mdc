# Skill: Creating a new frontend feature

Use when asked to add a new section, page, or feature to the frontend.

## Structure to create

```
features/{feature-name}/
├── components/
│   ├── {FeatureName}List.tsx      → Server Component (no 'use client')
│   ├── {FeatureName}Card.tsx      → Server Component
│   └── {FeatureName}Actions.tsx   → Client Component ('use client' — has events)
└── hooks/
    └── use{FeatureName}.ts        → Client hook — data + mutations
```

## Step 1 — API functions in lib/api/

```typescript
// lib/api/{feature-name}.ts
import { apiFetch } from "./client"
import type { {FeatureName}, Paginated{FeatureName}Response } from "@/types/{feature-name}"

export async function get{FeatureName}List(params?: Record<string, string>) {
  const query = new URLSearchParams(params)
  return apiFetch<Paginated{FeatureName}Response>(`/api/v1/{feature-name}/?${query}`)
}

export async function get{FeatureName}(id: number) {
  return apiFetch<{FeatureName}>(`/api/v1/{feature-name}/${id}/`)
}

export async function create{FeatureName}(data: Create{FeatureName}Input) {
  return apiFetch<{FeatureName}>(`/api/v1/{feature-name}/`, {
    method: "POST",
    body: JSON.stringify(data),
  })
}

export async function update{FeatureName}(id: number, data: Partial<Create{FeatureName}Input>) {
  return apiFetch<{FeatureName}>(`/api/v1/{feature-name}/${id}/`, {
    method: "PATCH",
    body: JSON.stringify(data),
  })
}

export async function delete{FeatureName}(id: number) {
  return apiFetch<void>(`/api/v1/{feature-name}/${id}/`, { method: "DELETE" })
}
```


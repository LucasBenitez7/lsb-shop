## Step 3 — Server Components (default, no directive)

```typescript
// features/{feature-name}/components/{FeatureName}List.tsx
// No 'use client' — this is a Server Component
import { get{FeatureName}List } from "@/lib/api/{feature-name}"
import { {FeatureName}Card } from "./{FeatureName}Card"
import { EmptyState } from "@/components/ui/empty-state"

interface Props {
  params?: Record<string, string>
}

export async function {FeatureName}List({ params }: Props) {
  const data = await get{FeatureName}List(params)

  if (data.results.length === 0) {
    return (
      <EmptyState
        title="Sin {feature-name} todavía"
        description="Crea el primero para empezar"
      />
    )
  }

  return (
    <div className="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {data.results.map((item) => (
        <{FeatureName}Card key={item.id} item={item} />
      ))}
    </div>
  )
}
```

## Step 4 — Client Components (add 'use client' only when needed)

```typescript
// features/{feature-name}/components/{FeatureName}Actions.tsx
"use client"  // needs onClick, state

import { useState } from "react"
import { toast } from "sonner"
import { delete{FeatureName} } from "@/lib/api/{feature-name}"
import type { {FeatureName} } from "@/types/{feature-name}"

interface Props {
  item: {FeatureName}
  onDeleted?: () => void
}

export function {FeatureName}Actions({ item, onDeleted }: Props) {
  const [isDeleting, setIsDeleting] = useState(false)

  const handleDelete = async () => {
    setIsDeleting(true)
    try {
      await delete{FeatureName}(item.id)
      toast.success("{FeatureName} eliminado correctamente.")
      onDeleted?.()
    } catch {
      toast.error("No pudimos eliminar el elemento. Inténtalo de nuevo.")
    } finally {
      setIsDeleting(false)
    }
  }

  return (
    <button onClick={handleDelete} disabled={isDeleting}>
      {isDeleting ? "Eliminando..." : "Eliminar"}
    </button>
  )
}
```

## Step 5 — Hook for mutations (Client only)

```typescript
// features/{feature-name}/hooks/use{FeatureName}.ts
"use client"

import { useState } from "react"
import { toast } from "sonner"
import { create{FeatureName}, update{FeatureName} } from "@/lib/api/{feature-name}"
import type { Create{FeatureName}Input } from "@/types/{feature-name}"

export function use{FeatureName}() {
  const [isSubmitting, setIsSubmitting] = useState(false)

  const create = async (data: Create{FeatureName}Input) => {
    setIsSubmitting(true)
    try {
      const result = await create{FeatureName}(data)
      toast.success("{FeatureName} creado correctamente.")
      return result
    } catch {
      toast.error("No pudimos crear el elemento. Inténtalo de nuevo.")
      throw error
    } finally {
      setIsSubmitting(false)
    }
  }

  return { create, isSubmitting }
}
```

## Step 6 — Form component with React Hook Form + Zod

```typescript
// features/{feature-name}/components/{FeatureName}Form.tsx
"use client"

import { useForm } from "react-hook-form"
import { zodResolver } from "@hookform/resolvers/zod"
import { z } from "zod"
import { use{FeatureName} } from "../hooks/use{FeatureName}"

const schema = z.object({
  name: z.string().min(1, "El nombre es obligatorio").max(255, "Máximo 255 caracteres"),
})

type FormData = z.infer<typeof schema>

export function {FeatureName}Form({ onSuccess }: { onSuccess?: () => void }) {
  const { create, isSubmitting } = use{FeatureName}()
  const {
    register,
    handleSubmit,
    reset,
    formState: { errors },
  } = useForm<FormData>({ resolver: zodResolver(schema) })

  const onSubmit = async (data: FormData) => {
    await create(data)
    reset()
    onSuccess?.()
  }

  return (
    <form onSubmit={handleSubmit(onSubmit)} className="space-y-4">
      <div>
        <label htmlFor="name">Nombre</label>
        <input id="name" {...register("name")} className="..." />
        {errors.name && <p className="text-red-500 text-sm">{errors.name.message}</p>}
      </div>
      <button type="submit" disabled={isSubmitting}>
        {isSubmitting ? "Guardando..." : "Guardar"}
      </button>
    </form>
  )
}
```

## Step 7 — Route page (app/) — Server Component, imports from feature

```typescript
// app/(site)/.../{feature-name}/page.tsx
import { Suspense } from "react"
import { {FeatureName}List } from "@/features/{feature-name}/components/{FeatureName}List"
import { {FeatureName}ListSkeleton } from "@/features/{feature-name}/components/{FeatureName}ListSkeleton"
import type { Metadata } from "next"

export const metadata: Metadata = {
  title: "{FeatureName} | LSB Shop",
  description: "...",
}

export default function {FeatureName}Page() {
  return (
    <main>
      <h1>{FeatureName}</h1>
      <Suspense fallback={<{FeatureName}ListSkeleton />}>
        <{FeatureName}List />
      </Suspense>
    </main>
  )
}
```

## Step 8 — loading.tsx alongside the page

```typescript
// app/(site)/.../{feature-name}/loading.tsx
export default function {FeatureName}Loading() {
  return <{FeatureName}ListSkeleton />
}
```

## Checklist

- [ ] API functions in `lib/api/{feature-name}.ts`
- [ ] TypeScript types in `types/{feature-name}.ts`
- [ ] Server Components have no `'use client'` directive
- [ ] Client Components have `'use client'` and a clear reason (events, state, browser API)
- [ ] Forms use React Hook Form + Zod
- [ ] All loading states handled (skeleton)
- [ ] All error states handled (ErrorState component)
- [ ] All empty states handled (EmptyState component)
- [ ] Toast messages are in human language — never raw error.message
- [ ] Images use `next/image` — never `<img>`
- [ ] `page.tsx` exports `metadata` or `generateMetadata`
- [ ] `loading.tsx` exists alongside every data-fetching page

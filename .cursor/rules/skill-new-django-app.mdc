### tests/conftest.py
```python
import pytest


@pytest.fixture
def {model_name}(db):
    from apps.{app_name}.tests.factories import {ModelName}Factory
    return {ModelName}Factory()
```

### tests/factories.py
```python
import factory
from factory.django import DjangoModelFactory
from factory import Faker
from apps.{app_name}.models import {ModelName}


class {ModelName}Factory(DjangoModelFactory):
    class Meta:
        model = {ModelName}

    name = Faker("sentence", nb_words=3)
    is_active = True
```

### tests/test_services.py
```python
import pytest
from apps.{app_name}.services import {ModelName}Service
from apps.{app_name}.tests.factories import {ModelName}Factory
from apps.core.exceptions import ResourceNotFound


@pytest.mark.django_db
class Test{ModelName}Service:

    def test_create_{model_name}(self):
        data = {"name": "Test Name"}
        instance = {ModelName}Service.create(data)
        assert instance.name == "Test Name"
        assert instance.is_active is True

    def test_delete_{model_name}_soft_deletes(self):
        instance = {ModelName}Factory()
        {ModelName}Service.delete(instance.id)
        instance.refresh_from_db()
        assert instance.is_active is False

    def test_update_{model_name}_raises_on_not_found(self):
        with pytest.raises(ResourceNotFound):
            {ModelName}Service.update(99999, {"name": "New"})
```

### tests/test_views.py
```python
import pytest
from apps.{app_name}.tests.factories import {ModelName}Factory


@pytest.mark.django_db
class Test{ModelName}ViewSet:

    def test_list_requires_auth(self, api_client):
        response = api_client.get("/api/v1/{app_name}/")
        assert response.status_code == 401

    def test_list_returns_results(self, auth_client):
        {ModelName}Factory.create_batch(3)
        response = auth_client.get("/api/v1/{app_name}/")
        assert response.status_code == 200
        assert response.data["count"] == 3

    def test_create_requires_admin(self, auth_client):
        response = auth_client.post("/api/v1/{app_name}/", {"name": "Test"})
        assert response.status_code == 403

    def test_create_as_admin(self, admin_client):
        response = admin_client.post("/api/v1/{app_name}/", {"name": "Test"})
        assert response.status_code == 201
```

## Step 4 — Register URLs in config/urls.py

```python
# config/urls.py
urlpatterns = [
    ...
    path("api/v1/", include("apps.{app_name}.urls")),
]
```

## Step 5 — Create and apply migration

```bash
python manage.py makemigrations --name "create_{app_name}_model"
python manage.py migrate
```

## Checklist before considering the app done

- [ ] Model extends TimeStampedModel
- [ ] Model has `__str__` method
- [ ] Model has proper indexes in Meta
- [ ] Selectors use `select_related`/`prefetch_related` if needed
- [ ] Services are tested without HTTP (test_services.py)
- [ ] ViewSet tests check auth (401) and admin-only (403)
- [ ] Admin is registered with django-unfold
- [ ] URLs registered in config/urls.py
- [ ] Migration created and applied

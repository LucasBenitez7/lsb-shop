# Skill: Creating a new Django app

Use this skill when asked to create a new app, add a new domain, or scaffold a new module in the backend.

## Step 1 — Create the app

```bash
cd backend
python manage.py startapp {app_name} apps/{app_name}
```

## Step 2 — Register in settings

```python
# config/settings/base.py
INSTALLED_APPS = [
    ...
    "apps.{app_name}",
]
```

## Step 3 — Create all required files

Every app MUST have exactly these files. Generate all of them:

### models.py
```python
from django.db import models
from apps.core.models import TimeStampedModel


class {ModelName}(TimeStampedModel):
    # fields here
    name = models.CharField(max_length=255, db_index=True)
    is_active = models.BooleanField(default=True)

    class Meta:
        ordering = ["-created_at"]
        indexes = [
            models.Index(fields=["is_active"]),
        ]

    def __str__(self) -> str:
        return self.name
```

### serializers.py
```python
from rest_framework import serializers
from apps.{app_name}.models import {ModelName}


class {ModelName}Serializer(serializers.ModelSerializer):
    class Meta:
        model = {ModelName}
        fields = ["id", "name", "is_active", "created_at"]
        read_only_fields = ["id", "created_at"]


class {ModelName}CreateSerializer(serializers.ModelSerializer):
    class Meta:
        model = {ModelName}
        fields = ["name"]
```

### selectors.py
```python
from django.db.models import QuerySet
from apps.{app_name}.models import {ModelName}


def get_{model_name}_list() -> QuerySet[{ModelName}]:
    return (
        {ModelName}.objects
        .filter(is_active=True)
        .order_by("-created_at")
    )


def get_{model_name}_by_id({model_name}_id: int) -> {ModelName}:
    return {ModelName}.objects.get(id={model_name}_id, is_active=True)
```

### services.py
```python
import structlog
from apps.core.exceptions import ResourceNotFound
from apps.{app_name}.models import {ModelName}
from apps.{app_name}.selectors import get_{model_name}_list, get_{model_name}_by_id

log = structlog.get_logger()


class {ModelName}Service:

    @staticmethod
    def get_list():
        return get_{model_name}_list()

    @staticmethod
    def create(data: dict) -> {ModelName}:
        instance = {ModelName}.objects.create(**data)
        log.info("{model_name}.created", {model_name}_id=instance.id)
        return instance

    @staticmethod
    def update({model_name}_id: int, data: dict) -> {ModelName}:
        try:
            instance = get_{model_name}_by_id({model_name}_id)
        except {ModelName}.DoesNotExist:
            raise ResourceNotFound()
        for key, value in data.items():
            setattr(instance, key, value)
        instance.save()
        log.info("{model_name}.updated", {model_name}_id=instance.id)
        return instance

    @staticmethod
    def delete({model_name}_id: int) -> None:
        try:
            instance = get_{model_name}_by_id({model_name}_id)
        except {ModelName}.DoesNotExist:
            raise ResourceNotFound()
        instance.is_active = False
        instance.save()
        log.info("{model_name}.deleted", {model_name}_id={model_name}_id)
```

### views.py
```python
from rest_framework import viewsets, filters
from rest_framework.permissions import IsAuthenticated, IsAdminUser
from django_filters.rest_framework import DjangoFilterBackend

from apps.{app_name}.models import {ModelName}
from apps.{app_name}.serializers import {ModelName}Serializer, {ModelName}CreateSerializer
from apps.{app_name}.services import {ModelName}Service
from apps.core.pagination import StandardPagination


class {ModelName}ViewSet(viewsets.ModelViewSet):
    queryset = {ModelName}.objects.none()
    pagination_class = StandardPagination
    filter_backends = [DjangoFilterBackend, filters.SearchFilter, filters.OrderingFilter]
    search_fields = ["name"]
    ordering_fields = ["created_at", "name"]

    def get_queryset(self):
        return {ModelName}Service.get_list()

    def get_serializer_class(self):
        if self.action in ["create", "update", "partial_update"]:
            return {ModelName}CreateSerializer
        return {ModelName}Serializer

    def get_permissions(self):
        if self.action in ["create", "update", "partial_update", "destroy"]:
            return [IsAdminUser()]
        return [IsAuthenticated()]

    def perform_create(self, serializer):
        {ModelName}Service.create(serializer.validated_data)
```

### urls.py
```python
from rest_framework.routers import DefaultRouter
from apps.{app_name}.views import {ModelName}ViewSet

router = DefaultRouter()
router.register("{app_name}", {ModelName}ViewSet, basename="{model_name}")

urlpatterns = router.urls
```


# Frontend — Vitest unit tests

```typescript
// features/catalog/components/__tests__/ProductCard.test.tsx
import { render, screen } from "@testing-library/react"
import { ProductCard } from "../ProductCard"

function createProduct(overrides = {}) {
  return {
    id: 1,
    name: "Camiseta Básica",
    price: "29.99",
    stock: 10,
    image_url: "/test.jpg",
    category_name: "Tops",
    ...overrides,
  }
}

describe("ProductCard", () => {
  it("renders product name and price", () => {
    render(<ProductCard product={createProduct()} />)
    expect(screen.getByText("Camiseta Básica")).toBeInTheDocument()
    expect(screen.getByText(/29/)).toBeInTheDocument()
  })

  it("shows out of stock badge when stock is 0", () => {
    render(<ProductCard product={createProduct({ stock: 0 })} />)
    expect(screen.getByText("Sin stock")).toBeInTheDocument()
  })
})

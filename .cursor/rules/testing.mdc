# Playwright E2E — critical flows only

```typescript
// e2e/checkout.spec.ts
import { test, expect } from "@playwright/test"

test.describe("Checkout flow", () => {
  test.beforeEach(async ({ page }) => {
    // Login via API to avoid testing login in every spec
    await page.request.post("/api/v1/auth/login/", {
      data: { email: process.env.E2E_USER_EMAIL, password: process.env.E2E_USER_PASSWORD }
    })
  })

  test("user can complete checkout with Stripe test card", async ({ page }) => {
    await page.goto("/catalogo")
    await page.click("[data-testid='add-to-cart']")
    await page.goto("/checkout")

    const stripeFrame = page.frameLocator("iframe[title='Stripe Payment Element']")
    await stripeFrame.locator("[placeholder='Card number']").fill("4242424242424242")
    await stripeFrame.locator("[placeholder='MM / YY']").fill("12/26")
    await stripeFrame.locator("[placeholder='CVC']").fill("123")

    await page.click("[data-testid='place-order']")
    await page.waitForURL("/checkout/success")
    await expect(page.locator("h1")).toContainText("¡Orden confirmada!")
  })
})
```

# Locust — load testing

```python
# locustfile.py
from locust import HttpUser, task, between


class ShopUser(HttpUser):
    wait_time = between(1, 3)
    token: str = ""

    def on_start(self):
        res = self.client.post("/api/v1/auth/login/", json={
            "email": "test@lsbshop.com",
            "password": "testpass123", # pragma: allowlist secret
        })
        if res.status_code == 200:
            self.token = res.json()["access"]

    def auth_headers(self):
        return {"Authorization": f"Bearer {self.token}"}

    @task(5)
    def browse_products(self):
        self.client.get("/api/v1/products/", headers=self.auth_headers())

    @task(3)
    def view_product(self):
        self.client.get("/api/v1/products/1/", headers=self.auth_headers())

    @task(2)
    def view_cart(self):
        self.client.get("/api/v1/cart/", headers=self.auth_headers())

    @task(1)
    def browse_categories(self):
        self.client.get("/api/v1/categories/", headers=self.auth_headers())

# CI smoke: locust -f locustfile.py --headless --users 10 --spawn-rate 2 --run-time 30s --host http://localhost:8000

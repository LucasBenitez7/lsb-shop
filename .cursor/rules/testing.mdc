# factory_boy — always, never create objects manually in tests

```python
# apps/products/tests/factories.py
import factory
from factory.django import DjangoModelFactory
from factory import Faker, SubFactory, LazyAttribute
from apps.products.models import Product, Category


class CategoryFactory(DjangoModelFactory):
    class Meta:
        model = Category

    name = Faker("word")
    slug = LazyAttribute(lambda o: o.name.lower().replace(" ", "-"))
    is_active = True


class ProductFactory(DjangoModelFactory):
    class Meta:
        model = Product

    name = Faker("sentence", nb_words=3)
    description = Faker("paragraph")
    price = Faker("pydecimal", left_digits=3, right_digits=2, positive=True)
    stock = Faker("random_int", min=1, max=100)
    is_active = True
    category = SubFactory(CategoryFactory)


# apps/users/tests/factories.py
from django.contrib.auth import get_user_model

User = get_user_model()


class UserFactory(DjangoModelFactory):
    class Meta:
        model = User

    email = Faker("email")
    first_name = Faker("first_name")
    last_name = Faker("last_name")
    is_active = True
    is_staff = False

    @classmethod
    def _create(cls, model_class, *args, **kwargs):
        return model_class.objects.create_user(**kwargs)


class AdminFactory(UserFactory):
    is_staff = True
```

# test_services.py — most important tests, no HTTP

```python
# apps/orders/tests/test_services.py
import pytest
from apps.orders.services import OrderService
from apps.orders.tests.factories import OrderFactory
from apps.products.tests.factories import ProductFactory
from apps.core.exceptions import InsufficientStock


@pytest.mark.django_db
class TestOrderService:

    def test_create_order_reduces_stock(self, user, product):
        product.stock = 10
        product.price = "25.00"
        product.save()

        order = OrderService.create_order(
            user=user,
            items=[{"product_id": product.id, "quantity": 3}]
        )

        product.refresh_from_db()
        assert product.stock == 7
        assert order.status == "pending"
        assert order.total == pytest.approx(75.00, rel=1e-2)

    def test_create_order_raises_on_insufficient_stock(self, user):
        product = ProductFactory(stock=2)

        with pytest.raises(InsufficientStock):
            OrderService.create_order(
                user=user,
                items=[{"product_id": product.id, "quantity": 5}]
            )

    def test_create_order_is_atomic_on_partial_failure(self, user):
        """If one item fails, no order created and no stock modified."""
        good = ProductFactory(stock=10)
        low = ProductFactory(stock=1)

        with pytest.raises(InsufficientStock):
            OrderService.create_order(
                user=user,
                items=[
                    {"product_id": good.id, "quantity": 2},
                    {"product_id": low.id, "quantity": 5},
                ]
            )

        good.refresh_from_db()
        assert good.stock == 10  # rolled back — atomic transaction
```

# test_views.py — integration tests with APIClient

```python
# apps/products/tests/test_views.py
import pytest


@pytest.mark.django_db
class TestProductViewSet:

    def test_list_requires_auth(self, api_client):
        response = api_client.get("/api/v1/products/")
        assert response.status_code == 401

    def test_list_returns_active_only(self, auth_client, db):
        ProductFactory.create_batch(3, is_active=True)
        ProductFactory.create_batch(2, is_active=False)

        response = auth_client.get("/api/v1/products/")

        assert response.status_code == 200
        assert response.data["count"] == 3

    def test_create_requires_admin(self, auth_client, category):
        data = {"name": "Camiseta", "price": "29.99", "stock": 10, "category": category.id}
        response = auth_client.post("/api/v1/products/", data)
        assert response.status_code == 403

    def test_create_as_admin(self, admin_client, category):
        data = {"name": "Camiseta", "price": "29.99", "stock": 10, "category": category.id}
        response = admin_client.post("/api/v1/products/", data)
        assert response.status_code == 201
        assert response.data["name"] == "Camiseta"
```

# Celery tasks — test synchronously with CELERY_TASK_ALWAYS_EAGER

```python
@pytest.mark.django_db
def test_send_order_confirmation(settings):
    settings.CELERY_TASK_ALWAYS_EAGER = True  # run sync, no broker needed
    order = OrderFactory(status="pending")

    send_order_confirmation(order.id)

    from django.core import mail
    assert len(mail.outbox) == 1
    assert order.user.email in mail.outbox[0].to

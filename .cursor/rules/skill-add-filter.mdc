## Frontend-only filter (small collections)

Only acceptable when all rows are already loaded (≤50 items):

```typescript
// lib/api/{domain}/server.ts
export async function getAdmin{Domain}(filters?: {Domain}Filters) {
  const res = await serverFetchJson<PaginatedResponse<Drf{Domain}>>(
    "/api/v1/{domain}/?page_size=500"  // fetch all
  )
  let items = res.results.map(mapRow)

  // Frontend-only filters (no backend param needed)
  if (filters?.filter === "featured") {
    items = items.filter((c) => c.isFeatured)
  } else if (filters?.filter === "empty") {
    items = items.filter((c) => c._count.products === 0)
  }

  return { items, total: filters?.filter ? items.length : res.count }
}
```


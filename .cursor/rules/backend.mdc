def cleanup_orphaned_cloudinary_images() -> None:
    """
    Runs weekly via Celery Beat (Sundays 3:30am).
    Compares all Cloudinary assets in FOLDER_PREFIX against DB references.
    Deletes assets not found in ProductImage.source_url, Category.image,
    Category.mobile_image, or StoreSettings banners.

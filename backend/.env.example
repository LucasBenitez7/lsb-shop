DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Orígenes del navegador que llaman al API con cookies (sin espacios tras comas).
# Producción ejemplo: https://shop.lsbstack.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Vacío en local. Con shop. + api. en el mismo sitio registrable, usar .lsbstack.com
JWT_AUTH_COOKIE_DOMAIN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/callback

DB_NAME=lsb_shop
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0

# Seconds to cache public GET /api/v1/products/ (paginated JSON). Bump invalidates via version key.
PRODUCT_LIST_CACHE_TTL=120

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

RESEND_API_KEY=re_...
DEFAULT_FROM_EMAIL=noreply@lsbshop.com

# Copy to `.env` and fill values. Do not commit `.env`.
# Local dev typically uses `DJANGO_SETTINGS_MODULE=config.settings.development` (see below).

# ── Django core ─────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-here
DEBUG=True
# Comma-separated hosts (no spaces after commas).
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS + links (must match your Next.js origin) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Empty in local. For shared cookie domain across subdomains, set e.g. .lsbstack.com
JWT_AUTH_COOKIE_DOMAIN=

# ── Google OAuth (optional — leave blank if unused) ─────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_NAME=lsb_shop
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# ── Redis (cache + Celery broker/result; same URL used for both) ────────────
REDIS_URL=redis://localhost:6379/0

# development: default true — registration / password-reset emails run in-process (no worker).
# Set false to test async email delivery (start Celery worker separately).
# CELERY_TASK_ALWAYS_EAGER=false

# GET /health/ — include Celery worker ping (needs broker + worker). Default false
# in development settings; set true to match production readiness checks.
# HEALTH_CHECK_CELERY_PING=true

# HTTP 5xx fingerprint counter in cache (Redis). Set false to disable logging bump.
# ERROR_FINGERPRINT_ENABLED=true
# ERROR_FINGERPRINT_TTL_SECONDS=86400

# Django Unfold demo staff (`python manage.py ensure_demo_staff`) — password required on first create
# ═══════════════════════════════════════════════════════════════════════════
# Demo users (portfolio & internal)
# ═══════════════════════════════════════════════════════════════════════════

# Portfolio demo user (Next admin only, NO Django admin): run `uv run python manage.py ensure_portfolio_demo`
# This user has role=demo, is_staff=False (cannot access Django /admin/), read-only in Next admin.
PORTFOLIO_DEMO_EMAIL=demoadmin@shop.lsbstack.com
PORTFOLIO_DEMO_PASSWORD=DemoLSB2026!  # Change in production; this is just for local/testing

# Internal staff Unfold user (Django /admin/ support, read-only): run `uv run python manage.py ensure_demo_staff`
# This user has role=demo, is_staff=True, view-only permissions. Keep this private (not in README).
# DEMO_STAFF_EMAIL=demo-staff@lsbshop.local
# DEMO_STAFF_PASSWORD=   # required on first create; set a strong secret (e.g. openssl rand -base64 32), never commit

# ── Optional tuning ─────────────────────────────────────────────────────────
# Seconds to cache public GET /api/v1/products/ (list JSON).
PRODUCT_LIST_CACHE_TTL=120
# Guest cart cookie TTL (seconds); default 604800 (7 days).
# CART_REDIS_TTL_SECONDS=604800
# CART_GUEST_COOKIE_NAME=lsb-cart-guest

# ── Cloudinary (media uploads; optional until you use admin/media features) ─
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PREFIX=lsb-shop

# ── Stripe (required for checkout PaymentIntent + webhook signature) ───────
# Test keys from Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen --forward-to ...` or Stripe Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Orders ───────────────────────────────────────────────────────────────────
# Unpaid pending orders older than this (minutes) are expired by Celery Beat.
ORDER_PENDING_EXPIRY_MINUTES=60

# ── Email ─────────────────────────────────────────────────────────────────────
# development.py: if RESEND_API_KEY is non-empty → real SMTP (Resend); else → console only.
RESEND_API_KEY=
# Must be an address/domain allowed by Resend (verify domain in Resend dashboard, or use their onboarding sender).
DEFAULT_FROM_EMAIL=noreply@lsbshop.com
# Optional overrides if not using Resend defaults:
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend

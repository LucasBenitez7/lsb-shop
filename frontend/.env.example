# Copy to `.env.local` and fill in. Never commit real secrets.

# Django API (browser + server fetch). Default: local backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Canonical site URL (metadata, sitemap, robots). Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Sign-In (same OAuth Web Client ID as backend GOOGLE_CLIENT_ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Stripe.js (checkout UI). Publishable key only.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudinary — widget uploads (`CldUploadWidget`, `SingleImageUpload`).
# Presets in this repo default to `lsb_shop` / `lsb_shop_banners` in code; set cloud name + keys below.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Optional overrides (defaults: lsb_shop / lsb_shop_banners).
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_PRODUCTS=
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_BANNERS=
# Optional single fallback for both helpers.
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Signed presets — required for uploads (dashboard presets are Signed).
# Same API Key as Cloudinary console; Secret only on the server for POST `/api/sign-cloudinary-params`.
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional duplicate of API Key for server-only; the sign route also accepts NEXT_PUBLIC_CLOUDINARY_API_KEY.
# CLOUDINARY_API_KEY=

# --- Server-only (Next.js Route Handlers). Add to `.env.local` if you test webhooks / Stripe server routes locally.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

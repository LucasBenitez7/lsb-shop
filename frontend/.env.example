# Django API (browser + Server Components fetch). Must match backend URL + CORS.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL (metadata, sitemap, robots, layout).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe.js (Payment Element). Publishable key only — safe in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server-only: same secret key as backend `STRIPE_SECRET_KEY`.
# Used by `app/(site)/(shop)/checkout/success/page.tsx` to read PaymentIntent (card brand/last4).
# CRITICAL: Without this, success page will error when Stripe is instantiated.
STRIPE_SECRET_KEY=sk_test_...

# ═══════════════════════════════════════════════════════════════════════════
# Optional — features
# ═══════════════════════════════════════════════════════════════════════════

# Google Sign-In (same Web Client ID as backend `GOOGLE_CLIENT_ID`).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudinary — uploads (`CldUploadWidget`, admin). Presets default to `lsb_shop` / `lsb_shop_banners`.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional preset overrides:
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_PRODUCTS=lsb_shop
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET_BANNERS=lsb_shop_banners
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Next.js route `app/webhooks/stripe` (only if you forward Stripe to Next instead of/in addition to Django).
# Note: This is different from the STRIPE_SECRET_KEY above (which is for success page).
# STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════════════════════════════════════════════════════════════════════
# Playwright E2E (not needed for normal dev — see `.env.e2e.example`)
# ═══════════════════════════════════════════════════════════════════════════
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_USER_EMAIL=
# E2E_USER_PASSWORD=
# E2E_ADMIN_EMAIL=
# E2E_ADMIN_PASSWORD=

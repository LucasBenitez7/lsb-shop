# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENV=development
NEXT_PUBLIC_DEFAULT_CURRENCY=EUR

# Database (use real credentials locally; avoid user:pass@ in examples for secret scanners)
